# Local docker-compose env. Copy to .env and tweak.
# ---------------------------------------------------------------------------

# SQL Server sa password. Must satisfy SQL Server complexity (≥8 chars, mix of
# upper/lower/digit/special).
MSSQL_SA_PASSWORD=DevP@ssw0rd!Local

# Azurite well-known dev key — never change. Both function apps and bootstrap
# read this. Hardcoded here for clarity; it is the one Azurite ships with.
AZURITE_CONN_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;QueueEndpoint=http://azurite:10001/devstoreaccount1;TableEndpoint=http://azurite:10002/devstoreaccount1;

# Embedding dim — must match the local embedding model's output. Bootstrap
# uses this to size the Qdrant collections.
#   nomic-embed-text       -> 768
#   mxbai-embed-large      -> 1024
#   all-minilm             -> 384
EMBEDDING_DIM=768

# Ollama models to pull during bootstrap (comma-separated).
OLLAMA_MODELS=qwen2.5:7b-instruct,nomic-embed-text

# Ollama model names referenced by the function apps. These must exist in the
# pull list above; the names below are passed through to the OpenAI client as
# the `model` parameter.
OLLAMA_MODEL_EXTRACTION=qwen2.5:7b-instruct
OLLAMA_MODEL_REASONING=qwen2.5:7b-instruct
OLLAMA_MODEL_EMBEDDING=nomic-embed-text
